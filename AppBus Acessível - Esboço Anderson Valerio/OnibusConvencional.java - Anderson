// ===== CONCEITO DE POO: HERANÇA =====
// Clase Ônibus Convencional
public class OnibusConvencional extends Veiculo {

    public OnibusConvencional(String placa) {
        super(placa);
    }

    // ===== CONCEITO DE POO: POLIMORFISMO (SOBREPOSIÇÃO) =====
    // O convencional divide rua com carro em Goiânia, então ele sempre atrasa 4 minutos.
    @Override
    public int calcularTempoComTrandito(int tempoOriginal) {
        return tempoOriginal + 4; 
    }
}
