<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ControleTela"
      prefWidth="390"
      prefHeight="760"
      spacing="12"
      style="-fx-background-color: #f4f6fb; -fx-font-family: Arial;">

    <padding>
        <Insets top="14" right="14" bottom="14" left="14" />
    </padding>

    <Label text="SIM RMTC"
           maxWidth="Infinity"
           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #172033;" />

    <Label text="Consulta de pontos, linhas e rotas."
           wrapText="true"
           style="-fx-font-size: 13; -fx-text-fill: #4b5568;" />

    <HBox spacing="8">
        <Button fx:id="botaoTelaPontoLinha"
                text="Ponto e linha."
                HBox.hgrow="ALWAYS"
                maxWidth="Infinity"
                onAction="#mostrarTelaPontoLinha" />
        <Button fx:id="botaoTelaRota"
                text="Pesquisa de rota."
                HBox.hgrow="ALWAYS"
                maxWidth="Infinity"
                onAction="#mostrarTelaRota" />
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <VBox fx:id="telaPontoLinha" spacing="10">
            <Label text="Pesquisa de ponto e linha."
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #172033;" />

            <Label text="Digite o codigo do ponto ou a localidade atual."
                   wrapText="true"
                   style="-fx-font-size: 12; -fx-text-fill: #4b5568;" />

            <HBox spacing="8">
                <TextField fx:id="campoPesquisaPontoLinha"
                           promptText="Ponto ou setor."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #d5dbea; -fx-padding: 11; -fx-background-color: white;" />
                <Button text="Buscar!"
                        onAction="#pesquisarPontoOuSetor"
                        style="-fx-background-color: #172033; -fx-text-fill: white; -fx-background-radius: 14; -fx-font-weight: bold; -fx-padding: 11;" />
            </HBox>

            <Label text="Pontos encontrados:"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #283044;" />

            <ListView fx:id="listaPontos"
                      prefHeight="170"
                      style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #d5dbea; -fx-background-color: white;" />

            <Label text="Linhas que passam pelo ponto:"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #283044;" />

            <ListView fx:id="listaLinhas"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #d5dbea; -fx-background-color: white;" />

            <Label fx:id="textoResultadoPontoLinha"
                   text="Pesquise um ponto ou setor."
                   maxWidth="Infinity"
                   minHeight="105"
                   wrapText="true"
                   style="-fx-background-color: #172033; -fx-text-fill: white; -fx-background-radius: 18; -fx-padding: 14; -fx-font-size: 14; -fx-font-weight: bold;" />
        </VBox>

        <VBox fx:id="telaRota" spacing="10" visible="false" managed="false">
            <Label text="Pesquisa de rota"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #172033;" />

            <Label text="Informe de onde voce está saindo e para onde deseja ir."
                   wrapText="true"
                   style="-fx-font-size: 12; -fx-text-fill: #4b5568;" />

            <TextField fx:id="campoOrigem"
                       promptText="Localidade de origem."
                       style="-fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #d5dbea; -fx-padding: 12; -fx-background-color: white;" />

            <TextField fx:id="campoDestino"
                       promptText="Localidade de destino."
                       style="-fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #d5dbea; -fx-padding: 12; -fx-background-color: white;" />

            <Button text="Calcular rota!"
                    maxWidth="Infinity"
                    onAction="#calcularRota"
                    style="-fx-background-color: #172033; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-weight: bold; -fx-padding: 12;" />

            <Label fx:id="textoTamanhoRota"
                   text="A rota calculada aparecera aqui."
                   maxWidth="Infinity"
                   minHeight="130"
                   wrapText="true"
                   style="-fx-background-color: white; -fx-text-fill: #172033; -fx-background-radius: 18; -fx-border-color: #d5dbea; -fx-border-radius: 18; -fx-padding: 14; -fx-font-size: 14; -fx-font-weight: bold;" />

            <Label text="Linhas sugeridas para a rota:"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #283044;" />

            <ListView fx:id="listaLinhasRota"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #d5dbea; -fx-background-color: white;" />
        </VBox>
    </StackPane>
</VBox>
